# ─────────────────────────────────────────────────────────────────────────────
# AI Employee Dashboard — environment variables
#
# Local dev:   copy this to .env.local and fill in values.
# Production:  set these in Vercel Project Settings → Environment Variables.
#              For secrets (@api_url etc.) set via: vercel env add
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask API URL ──────────────────────────────────────────────────────────────
# The base URL for the Flask backend (no trailing slash).
#
#   Local dev:   leave EMPTY — next.config.ts proxies /api/* → localhost:5000
#   Production:  set to your deployed Flask URL, e.g. https://api.example.com
#
# Exposed to the browser. Do NOT put tokens or secrets here.
NEXT_PUBLIC_API_URL=

# ── Auth cookie name ───────────────────────────────────────────────────────────
# The name of the non-sensitive presence cookie used by Next.js middleware
# to gate dashboard routes on the server.
#
# IMPORTANT: This value must match the COOKIE_NAME constant in lib/auth.ts.
# If you rename one, rename the other. Default: ai_employee_auth
AUTH_COOKIE_NAME=ai_employee_auth

# ── Optional overrides ─────────────────────────────────────────────────────────
# Uncomment and fill in to customise behaviour.

# App name shown in browser tab (via next/head metadata)
# NEXT_PUBLIC_APP_NAME=AI Employee Dashboard
